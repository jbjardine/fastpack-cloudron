# Live Cloudron E2E tests
# Copy these values into your shell environment before running live E2E scripts.

FASTPACK_E2E_CLOUDRON_URL=https://my.example.com
FASTPACK_E2E_CLOUDRON_DOMAIN=example.com
FASTPACK_E2E_SSH_HOST=user@example.com
FASTPACK_E2E_SUDO_PASSWORD=change-me
FASTPACK_E2E_REGISTRY=devtools.example.com
FASTPACK_E2E_SUBDOMAIN=fpgo

# Optional: token flow for test-go-deploy-e2e.mjs
CLOUDRON_TOKEN=change-me
